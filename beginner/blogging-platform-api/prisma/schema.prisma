generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int     @id @default(autoincrement())
  username     String  @unique
  firstName    String
  lastName     String
  password     String
  refreshToken String?
  posts        Post[]
}

model Post {
  id         Int        @id @default(autoincrement())
  title      String     @db.VarChar(255)
  content    String
  authorId   Int
  author     User       @relation(fields: [authorId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[]
  tags       Tag[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  posts Post[]
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String
  posts Post[]
}
